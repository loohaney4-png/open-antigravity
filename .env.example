# Docker Compose environment
NODE_ENV=development
DB_USER=antigravity
DB_PASSWORD=changeme
DB_NAME=open_antigravity
LOG_LEVEL=info

# ============================================
# AI MODEL CONFIGURATION
# ============================================
# DEFAULT: Ollama (Free, Open-Source, Local)
# Ollama runs completely locally on your machine - no API keys needed!
# Download: https://ollama.ai
# Setup: ollama pull mistral (then ollama serve)

OLLAMA_ENDPOINT=http://localhost:11434
DEFAULT_MODEL=mistral

# Optional: Add your own API keys for premium models (these are optional)
# OPENAI_API_KEY=sk-... (requires paid OpenAI account)
# ANTHROPIC_API_KEY=sk-ant-... (requires paid Anthropic account)
# GOOGLE_API_KEY=... (requires Google Cloud setup)
