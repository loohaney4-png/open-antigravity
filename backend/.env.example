# Backend environment configuration
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=antigravity
DB_PASSWORD=changeme
DB_NAME=open_antigravity

# Redis
